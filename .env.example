# ═══════════════════════════════════════════════════════════
#  BASTION Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── AWS General ──
AWS_REGION=us-east-1

# ── S3 (Input Layer) ──
BASTION_S3_BUCKET=bastion-data-lake

# ── DynamoDB (Storage Layer) ──
BASTION_DYNAMODB_TABLE=bastion-results

# ── Pinecone (Vector Store) ──
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=bastion-vectors
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=384
# Note: Use 384 for semantic embeddings (default), 128 for hash-based (legacy)

# ── SQS (Buffer Queue) ──
BASTION_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/bastion-analysis-queue

# ── Gemini (LLM) ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.1
# GEMINI_BASE_URL=https://your-proxy.example.com/gemini  (optional)

# ── Athena (Forensic queries) ──
ATHENA_DATABASE=bastion_cloudtrail
ATHENA_OUTPUT_BUCKET=s3://bastion-athena-results/

# ── ML Models (Feature Flags) ──
BASTION_USE_ML_CLASSIFIER=true
# Enable BERT-based phishing classifier (Tier 1 email filter)
# Requires: transformers, torch (~250MB model download on first run)
# Fallback: Pure regex if model fails to load

BASTION_USE_SEMANTIC_EMBEDDINGS=true
# Enable Sentence-BERT semantic embeddings for vector search
# Requires: sentence-transformers (~80MB model download)
# Fallback: Hash-based embeddings if model fails
# Important: PINECONE_DIMENSION must be 384 when enabled

BASTION_USE_LSTM_UBA=true
# Enable LSTM Autoencoder for User Behavior Analytics (Tier 1 forensic)
# Requires: torch (~5MB model, needs training first)
# Fallback: Isolation Forest only if model fails
# Training: python scripts/train_lstm_uba.py --data logs.json

# ── Logging ──
LOG_LEVEL=DEBUG
ENVIRONMENT=development
